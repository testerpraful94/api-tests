		{
			"name": "Add to Cart",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "4a321109-0972-4908-8363-ec8d95b82642",
						"exec": [
							"pm.test(\"Status code is 201\", function(){\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"\r",
							"let jsonData = pm.response.json();\r",
							"\r",
							"pm.test(\"Cart Id is not null\",function(){\r",
							"    pm.expect(jsonData.products.length).to.be.above(0)\r",
							"});\r",
							"\r",
							"pm.environment.set(\"cart_id\",jsonData.id)\r",
							"\r",
							"console.log(\"Cart is created successfully\");"
						],
